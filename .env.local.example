# Command Center environment variables
# Copy this to .env.local and fill in your actual values
# .env.local is gitignored — never commit it

# Password to unlock the Command Center
APP_PASSWORD="your_password_here"

# Upstash Redis credentials (from Vercel Marketplace or Upstash dashboard)
KV_REST_API_URL="https://your-upstash-instance.upstash.io"
KV_REST_API_TOKEN="your_rest_api_token_here"
KV_REST_API_READ_ONLY_TOKEN="your_readonly_token_here"

# Alternative naming scheme (if using direct Upstash setup)
# UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your_token_here"
